<script type="text/javascript">
    document.addEventListener("DOMContentLoaded", function() {
        // 1. Handler Dropdown Item
        const dropdownItems = document.querySelectorAll(".dropdown-menu a");

        dropdownItems.forEach(item => {
            item.addEventListener("click", function(e) {
                e.preventDefault();

                const value = this.getAttribute("data-value");
                const text = this.textContent;

                const dropdownContainer = this.closest(".col-md-6");
                const buttonLabel = dropdownContainer.querySelector("button span");

                buttonLabel.textContent = text;

                if (dropdownContainer.id === "ctx-status") {
                    document.getElementById("input-status").value = value;
                } else if (dropdownContainer.id === "ctx-level") {
                    document.getElementById("input-level").value = value;
                } else if (dropdownContainer.id === "ctx-role") {
                    document.getElementById("input-role").value = value;
                }
            });
        });

        // 2. Inisialisasi Instansiasi Modal Bootstrap
        var modalKonfirmasi = new bootstrap.Modal(document.getElementById('modalKonfirmasiEdit'));
        var modalLoading = new bootstrap.Modal(document.getElementById('modalLoadingEdit'));
        var modalSukses = new bootstrap.Modal(document.getElementById('modalSuksesEdit'));

        // 3. Intersepsi Form Submit
        document.getElementById('formEditUser').addEventListener('submit', function(event) {
            event.preventDefault();

            const levelVal = document.getElementById('input-level').value;
            const roleVal = document.getElementById('input-role').value;

            if (levelVal === "" || roleVal === "") {
                alert("Mohon lengkapi pilihan Level User dan Role terlebih dahulu.");
                return false;
            }

            modalKonfirmasi.show();
        });

        // 4. Proses Submit via Fetch API AJAX dengan Animasi Loading & Sukses
        document.getElementById('btnProsesUpdate').addEventListener('click', function() {
            modalKonfirmasi.hide();
            modalLoading.show();

            const form = document.getElementById('formEditUser');
            const formData = new FormData(form);

            fetch(form.action, {
                    method: 'POST',
                    body: formData
                })
                .then(response => {
                    // Jika response HTTP bermasalah (bukan 200), lempar teks error mentahnya
                    if (!response.ok) {
                        return response.text().then(text => {
                            throw new Error(text)
                        });
                    }
                    return response.json();
                })
                .then(data => {
                    modalLoading.hide();

                    if (data.success || data.code == 200) {
                        modalSukses.show();
                    } else {
                        alert("Gagal memperbarui data: " + data.msg);
                    }
                })
                .catch(error => {
                    modalLoading.hide();
                    // Memunculkan detail crash PHP asli ke layar untuk mempermudah pelacakan
                    console.error("Error Detail:", error.message);
                    alert("Terjadi kesalahan sistem:\n" + error.message.substring(0, 200));
                });
        });

        // 5. Redirect Ke Halaman Awal Kelola User saat Klik Oke
        document.getElementById('btnSelesaiEdit').addEventListener('click', function() {
            modalSukses.hide();
            window.location.href = "<?= $this->baseUrl('user'); ?>";
        });
    });
</script>