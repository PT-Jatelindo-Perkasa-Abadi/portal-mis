// MURNI BERSIH: Mengamankan variabel agar selalu berupa array.
$user = (isset($this->userDetail) && is_array($this->userDetail)) ? $this->userDetail : [];

// Ambil field asli dari BE Go (Sudah dibersihkan dari invisible spaces)
$currentId        = isset($user['id']) ? $user['id'] : '';
$currentFullName  = isset($user['full_name']) ? $user['full_name'] : '';
$currentEmail     = isset($user['email']) ? $user['email'] : '';
$currentLevelName = isset($user['level_name']) ? trim($user['level_name']) : '';
$currentRoleName  = isset($user['role_name']) ? trim($user['role_name']) : '';

// 1. Normalisasi Status User
$isActive  = isset($user['is_active']) ? $user['is_active'] : 0;
$isBlocked = isset($user['is_blocked']) ? $user['is_blocked'] : 0;

$statusText = 'Non-Aktif';
$statusVal  = '0';
if ($isBlocked == 1) {
    $statusText = 'Blokir';
    $statusVal  = 'block';
} elseif ($isActive == 1) {
    $statusText = 'Aktif';
    $statusVal  = '1';
}

// 2. Normalisasi Level User (Konversi String dari BE menjadi Angka ID Database untuk Input value)
$levelText = 'Pilih Level User';
$levelVal  = '';

if (strcasecmp($currentLevelName, 'Admin MIS') === 0 || strcasecmp($currentLevelName, 'MIS') === 0) {
    $levelText = 'Admin MIS';
    $levelVal  = '1';
} elseif (strcasecmp($currentLevelName, 'IT Provider') === 0) {
    $levelText = 'IT Provider';
    $levelVal  = '2';
} elseif (strcasecmp($currentLevelName, 'Guest MIS') === 0) {
    $levelText = 'Guest MIS';
    $levelVal  = '8';
}

// 3. Normalisasi Role (Administrator = 2, Viewer = 1)
$roleText = 'Pilih Role';
$roleVal  = '';
if (strcasecmp($currentRoleName, 'admin') === 0 || strcasecmp($currentRoleName, 'administrator') === 0) {
    $roleText = 'Administrator';
    $roleVal  = '2'; // ID Baru untuk Administrator
} elseif (strcasecmp($currentRoleName, 'viewer') === 0 || strcasecmp($currentRoleName, 'user') === 0) {
    $roleText = 'Viewer';
    $roleVal  = '1'; // ID Baru untuk Viewer
}
