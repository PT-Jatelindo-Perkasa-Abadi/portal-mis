<script type="text/javascript">
document.addEventListener("DOMContentLoaded", function() {
    const modalKonfirmasi = new bootstrap.Modal(document.getElementById('modalKonfirmasi'));
    const modalLoading = new bootstrap.Modal(document.getElementById('modalLoading'));
    const modalSukses = new bootstrap.Modal(document.getElementById('modalSukses'));

    const dropdownItems = document.querySelectorAll(".dropdown-menu a");
    dropdownItems.forEach(item => {
        item.addEventListener("click", function(e) {
            e.preventDefault();
            const value = this.getAttribute("data-value");
            const text = this.textContent;
            const dropdownContainer = this.closest(".col-md-6");
            const buttonLabel = dropdownContainer.querySelector("button span");
            
            buttonLabel.textContent = text;
            buttonLabel.style.setProperty('color', '#12161C', 'important');
            
            if (dropdownContainer.id === "ctx-status") {
                document.getElementById("input-status").value = value;
            } else if (dropdownContainer.id === "ctx-level") {
                document.getElementById("input-level").value = value;
            } else if (dropdownContainer.id === "ctx-role") {
                document.getElementById("input-role").value = value;
            }
        });
    });

    document.getElementById('formTambahUser').addEventListener('submit', function(event) {
        event.preventDefault(); 
        modalKonfirmasi.show();
    });

    document.getElementById('btnProsesSubmit').addEventListener('click', function() {
        modalKonfirmasi.hide();
        modalLoading.show();

        const formData = new FormData();
        formData.append('status', document.getElementById('input-status').value);
        formData.append('level_user', document.getElementById('input-level').value);
        formData.append('role', document.getElementById('input-role').value);
        formData.append('email', document.getElementById('email').value);
        formData.append('fullName', document.getElementById('fullName').value);

        fetch('<?= $this->baseUrl("user/index/save"); ?>', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            setTimeout(() => {
                modalLoading.hide();
                if (data.success) {
                    modalSukses.show();
                } else {
                    alert("Gagal menambahkan user: " + data.msg);
                }
            }, 600);
        })
        .catch(error => {
            modalLoading.hide();
            alert("Terjadi kendala koneksi ke server backend.");
        });
    });

    document.getElementById('btnSuksesOke').addEventListener('click', function() {
        modalSukses.hide();
        window.location.href = '<?= $this->baseUrl("user/index/index"); ?>';
    });
});
</script>