<div class="d-flex">
    <img src="<?= $this->baseUrl('/assets/img/logo-mis-black.svg'); ?>" class="d-flex d-md-none img-fluid w-100"
        alt="logo jatelindo">
</div>
<form id="forgot-password-form" class="form form-validation" action="<?= $this->baseUrl('auth/send-otp'); ?>"
    autocomplete="off">
    <div class="form-header">
        <h1 class="form-header-title">Lupa Kata Sandi</h1>
        <p class="form-header-description">
            Masukkan email terdaftar Anda, dan kami akan mengirimkan kode OTP untuk membuat kata sandi baru Anda.
        </p>
    </div>
    <div class="form-content">
        <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <input id="email" type="email" name="email" class="form-control" placeholder="Masukkan email" required />
            <div class="form-feedback"></div>
        </div>
    </div>
    <div class="form-footer">
        <button type="submit" class="btn btn-primary btn-full w-full">
            Kirim Kode OTP
        </button>
    </div>
</form>
<!-- OTP Modal -->
<div class="modal fade" id="otpModal" tabindex="-1" aria-labelledby="otpModalLabel" aria-hidden="true"
    data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="otpModalLabel">Kode OTP</h5>
            </div>
            <div class="modal-body">
                <p class="text-sm mb-4">
                    Silakan masukkan OTP 6 digit yang dikirimkan ke
                    <span class="text-dark-70 font-bold" id="otpEmailTarget"></span>
                </p>
                <div class="form-otp">
                    <div class="otp-input-group">
                        <input type="text" name="otpCode[]" maxlength="1" />
                        <input type="text" name="otpCode[]" maxlength="1" />
                        <input type="text" name="otpCode[]" maxlength="1" />
                        <input type="text" name="otpCode[]" maxlength="1" />
                        <input type="text" name="otpCode[]" maxlength="1" />
                        <input type="text" name="otpCode[]" maxlength="1" />
                        <span class="otp-loader"></span>
                    </div>
                    <p class="d-none otp-error-message"></p>
                </div>
            </div>
            <div class="modal-footer justify-content-start border-top-0">
                <p class="text-dark-70 text-sm mb-0">
                    Kirim Ulang Kode
                    <span class="resend-count">1/3</span>
                    <span class="text-dark-70 font-bold timer-otp">01:00</span>
                </p>
            </div>
        </div>
    </div>
</div>

<p class="auth-tos">
</p>

<script type="text/javascript">
$(document).ready(function() {
    app.FormValidation.init("#forgot-password-form");

    let timerInterval = null;

    // OTP pertama sudah dihitung sebagai 1/3
    let resendCount = 1;
    const maxResend = 3;
    let isResendingOtp = false;

    function updateResendCounter() {
        $('.resend-count').text(`${resendCount}/${maxResend}`);
    }

    function resetOtpState() {
        resendCount = 1;
        isResendingOtp = false;

        $('.otp-error-message').addClass('d-none');
        updateResendCounter();
    }

    function startOtpTimer() {
        if (timerInterval) {
            clearInterval(timerInterval);
        }

        let duration = 60;

        $('.timer-otp').text('01:00');

        timerInterval = setInterval(function() {
            let minutes = Math.floor(duration / 60);
            let seconds = duration % 60;

            minutes = minutes < 10 ? '0' + minutes : minutes;
            seconds = seconds < 10 ? '0' + seconds : seconds;

            $('.timer-otp').text(`${minutes}:${seconds}`);

            duration--;

            if (duration < 0) {
                clearInterval(timerInterval);
                isResendingOtp = false;

                if (resendCount < maxResend) {
                    $('.timer-otp').html(
                        '<a href="#" id="resendOtp">Resend OTP</a>'
                    );
                } else {
                    $('.timer-otp').text('OTP mencapai limit');
                }
            }
        }, 1000);
    }

    $('#forgot-password-form').on('submit', function(e) {
        e.preventDefault();

        const form = $(this);

        $.ajax({
            url: form.attr('action'),
            type: 'POST',
            dataType: 'JSON',
            data: form.serialize(),
            beforeSend: function() {
                $('#modalLoading').modal('show');

                form.find('button[type="submit"]')
                    .prop('disabled', true);
            },
            success: function(response) {
                if (!response.success) {
                    setTimeout(() => {
                        app.FormValidation.feedback('#email', response.message);
                    }, 500);

                    return;
                }

                resetOtpState();

                $('#otpEmailTarget').text($('#email').val());

                setTimeout(() => {
                    $('#otpModal').modal('show');
                    $('.otp-input-group')
                        .find('input')
                        .first()
                        .focus();
                }, 500);

                startOtpTimer();
            },
            error: function() {
                app.FormValidation.feedback(
                    '#email',
                    'Failed to send OTP. Please try again.'
                );
            },
            complete: function() {
                setTimeout(() => {
                    $('#modalLoading').modal('hide');
                    form.find('button[type="submit"]').prop('disabled', false);
                }, 300);

            }
        });
    });

    const OtpCallback = (value) => {
        inputOtp.isError(false);
        inputOtp.showLoading();

        $.ajax({
            url: "<?= $this->baseUrl('auth/verify-otp-process'); ?>",
            type: "POST",
            dataType: "JSON",
            data: {
                email: $('#email').val(),
                otp: value
            },
            success: function(response) {
                inputOtp.hideLoading();

                if (response.success) {
                    window.location.href = response.redirect;
                    return;
                }

                $('.otp-error-message')
                    .text(response.message)
                    .removeClass('d-none');

                inputOtp.isError(true);
            },
            error: function() {
                inputOtp.hideLoading();
                inputOtp.isError(true);

                $('.otp-error-message')
                    .text('Failed to verify OTP.')
                    .removeClass('d-none');
            }
        });
    };

    const inputOtp = app.InputOtp.init(
        OtpCallback
    );

    $(document).on('click', '#resendOtp', function(e) {
        e.preventDefault();

        if (isResendingOtp) {
            return false;
        }

        if (resendCount >= maxResend) {
            $('.otp-error-message')
                .text('Batas pengiriman OTP telah tercapai.')
                .removeClass('d-none');

            return false;
        }

        isResendingOtp = true;

        $.ajax({
            url: "<?= $this->baseUrl('auth/send-otp'); ?>",
            type: "POST",
            dataType: "JSON",
            data: {
                email: $('#email').val()
            },
            success: function(response) {
                if (!response.success) {
                    $('.otp-error-message')
                        .text(response.message)
                        .removeClass('d-none');

                    isResendingOtp = false;

                    return;
                }

                resendCount++;
                updateResendCounter();

                $('.otp-error-message').addClass('d-none');

                startOtpTimer();
            },
            error: function() {
                $('.otp-error-message')
                    .text('Failed to resend OTP.')
                    .removeClass('d-none');

                isResendingOtp = false;
            }
        });
    });

    $('#otpModal').on('hidden.bs.modal', function() {
        if (timerInterval) {
            clearInterval(timerInterval);
        }

        isResendingOtp = false;
    });

    updateResendCounter();
});
</script>