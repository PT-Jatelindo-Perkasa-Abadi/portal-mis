nt;\n    }\n\n    .header {\n        background-image: url(\"assets\/img\/Background.svg\");\n        background-size: cover;\n        background-position: top center;\n        background-repeat: no-repeat;\n        color: #ffffff;\n        padding: 32px;\n        margin: 0;\n        display: block;\n    }\n\n    .content {\n        padding: 15px;\n        color: #333333;\n        line-height: 1.6;\n    }\n\n    .content h2 {\n        margin-top: 0;\n        font-size: 24px;\n        color: #000000;\n    }\n\n    .info-table {\n        width: 100%;\n        margin-top: 20px;\n        border-collapse: collapse;\n    }\n\n    .info-table td {\n        padding: 5px 0;\n        vertical-align: top;\n        font-size: 15px;\n    }\n\n    .label {\n        width: 120px;\n        font-weight: bold;\n    }\n\n    .footer {\n        background-color: #f9f9f9;\n        padding: 24px 32px;\n        text-align: center;\n        font-size: 12px;\n        color: #888888;\n        border-top: 1px solid #eeeeee;\n    }\n\n    .btn-link {\n        color: #007bff;\n        text-decoration: none;\n        font-weight: bold;\n    }\n\n    hr {\n        border: 0;\n        border-top: 1px solid #eeeeee;\n        margin: 30px 0;\n    }\n\n    @media only screen and (min-width: 621px) {\n        body {\n            background-color: #fff;\n            color: #12161c;\n        }\n\n        .logo-white {\n            display: none !important;\n        }\n\n        .logo-dark {\n            display: block !important;\n        }\n\n        .pre-code {\n            font-size: 1.5rem !important;\n        }\n\n        .text-company {\n            color: #888a8d !important;\n        }\n\n        .text-company,\n        .font-heading,\n        .font-body {\n            font-size: 1rem !important;\n        }\n\n        .font-heading,\n        .font-body {\n            color: #12161c !important;\n        }\n    }\n\n    @media screen and (max-width: 620px) {\n        @media (prefers-color-scheme: dark) {\n            body {\n                background-color: #2a2d33 !important;\n            }\n\n            .logo-white {\n                display: block;\n            }\n\n            .pre-code {\n                background-color: #727272;\n                border-color: #727272;\n            }\n\n            .border-color {\n                border-left: 1px solid #5a5a5a;\n                border-right: 1px solid #5a5a5a;\n            }\n\n            .border-color-2 {\n                border-left: 1px solid #5a5a5a;\n                border-right: 1px solid #5a5a5a;\n                border-bottom: 1px solid #5a5a5a;\n            }\n\n            .hr {\n                margin: 0;\n                padding: 0;\n                border: 1px solid #e7e8e8;\n            }\n\n            .text-company,\n            .font-heading,\n            .font-body {\n                color: #fff;\n            }\n        }\n    }\n    <\/style>\n<\/head>\n\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n    <table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n        <tr>\n            <td style=\"\n                font-size: 22px;\n                font-weight: bold;\n                color: #ffffff;\n                vertical-align: middle;\">\n                Portal Disbursement\n            <\/td>\n            <td align=\"right\" style=\"vertical-align: middle\">\n                <img src=\"assets\/img\/img-logo-jatelindo.svg\" alt=\"Logo Jatelindo\"\n                    style=\"display: block; height: 35px; width: auto\" \/>\n            <\/td>\n        <\/tr>\n    <\/table>\n<\/div>        <div class=\"content\">\n    <h2>Halo, Portal Disbursement<\/h2>\n    <p>Use the OTP below to reset your password.<\/p>\n\n    <table class=\"info-table\">\n        <tr>\n            <td class=\"label\">Email<\/td>\n            <td>adetrihadi@jatelindo.co.id<\/td>\n        <\/tr>\n    <\/table>\n\n\n    <tr>\n        <td style=\"padding-top: 0px\">\n  