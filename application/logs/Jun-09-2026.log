er-radius: 8px;\n        width: fit-content;\n    }\n\n    .header {\n        background-image: url('http:\/\/wp-disbursement.localhost\/assets\/img\/background-header-email.png');\n        background-size: cover;\n        background-position: top center;\n        background-repeat: no-repeat;\n        color: #ffffff;\n        padding: 32px;\n        margin: 0;\n        display: block;\n    }\n\n    .content-cell {\n        padding: 32px !important;\n        \/* Memaksa padding 32px atas, bawah, kanan, kiri *\/\n        color: #333333;\n        line-height: 1.6;\n        text-align: left;\n    }\n\n    \/* Selector h2 disesuaikan dengan pembungkus barunya *\/\n    .content-cell h2 {\n        margin-top: 0;\n        margin-bottom: 24px;\n        font-size: 20px;\n        color: #000000;\n        font-weight: 400;\n        \/* \"Halo,\" reguler *\/\n        text-align: left;\n    }\n\n    .content-cell h2 strong {\n        font-weight: 700;\n        \/* Variabel bold *\/\n    }\n\n    .content-cell p {\n        margin-top: 0;\n        \/* margin-bottom: 16px; *\/\n        font-size: 14px;\n        color: #1c1c1c;\n        text-align: left;\n    }\n\n    .info-table {\n        width: 100%;\n        margin-top: 16px;\n        border-collapse: collapse;\n    }\n\n    .info-table td {\n        padding: 8px 0;\n        \/* Jarak vertikal antar baris *\/\n        vertical-align: top;\n        font-size: 15px;\n        color: #1c1c1c;\n    }\n\n    .info-table .label {\n        width: 180px;\n        \/* Lebar kolom kiri agar teks muat satu baris *\/\n        white-space: nowrap;\n        \/* Memaksa teks label tetap lurus ke samping *\/\n        font-weight: 400;\n        \/* Memastikan teks kiri TIDAK TEBAL (Reguler) *\/\n    }\n\n    .info-table .colon {\n        width: 20px;\n        \/* Jarak untuk tanda titik dua (:) agar lurus vertikal *\/\n        text-align: center;\n        font-weight: 400;\n        \/* Titik dua tidak tebal *\/\n    }\n\n    .info-table .value {\n        font-weight: 700;\n        \/* Membuat variabel {{...}} di sebelah kanan menjadi TEBAL *\/\n    }\n\n    .label {\n        width: 120px;\n        font-weight: bold;\n    }\n\n    .footer {\n        background-color: #f9f9f9;\n        padding: 24px 32px;\n        text-align: center;\n        font-size: 12px;\n        color: #888888;\n        border-top: 1px solid #eeeeee;\n    }\n\n    .btn-link {\n        color: #007bff;\n        text-decoration: none;\n        font-weight: bold;\n    }\n\n    .btn-click {\n        display: inline-block;\n        background-color: #3A7BF6;\n        \/* Sesuai Hex di Figma *\/\n        color: #ffffff !important;\n        \/* Warna teks putih *\/\n        font-family: \"Sora\", sans-serif;\n        font-size: 14px;\n        font-weight: 700;\n        \/* Bold *\/\n        text-decoration: none;\n        \/* Menghilangkan garis bawah tautan *\/\n        padding: 10px 16px;\n        \/* Padding sesuai Figma (Top\/Bottom Left\/Right) *\/\n        line-height: 28px;\n        \/* Menjaga total tinggi elemen mendekati 48px *\/\n        border-radius: 8px;\n        \/* Radius sesuai Figma *\/\n        text-align: center;\n    }\n\n    hr {\n        border: 0;\n        border-top: 1px solid #eeeeee;\n        margin: 30px 0;\n    }\n\n    @media only screen and (min-width: 651px) {\n        body {\n            background-color: #f4f4f4;\n            color: #12161c;\n        }\n\n        .logo-white {\n            display: none !important;\n        }\n\n        .logo-dark {\n            display: block !important;\n        }\n\n        .pre-code {\n            font-size: 1.5rem !important;\n        }\n\n        .text-company {\n            color: #888a8d !important;\n        }\n\n        .text-company,\n        .font-heading,\n        .font-body {\n            font-size: 1rem !important;\n        }\n\n        .font-heading,\n        .font-body {\n            color: #12161c !important;\n        }\n    }\n\n    \/* =======================