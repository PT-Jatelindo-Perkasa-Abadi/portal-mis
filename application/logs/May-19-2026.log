19-May-2026 19:07:01 INFO: IP: 127.0.0.1 | ACTIVITY_ID: 6a0c5265707c0 | REQUEST TO http://182.23.62.7:8299/service/email METHOD=POST BODY={"to":["adetrihadi@jatelindo.co.id"],"subject":"Reset Password OTP","body":"<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"utf-8\" \/>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\" \/>\n    <title>Reset Password OTP<\/title>\n    <meta name=\"theme-color\" content=\"#0092D5\">\n    <link rel=\"icon\" href=\"\/assets\/img\/cropped-Jatelindo-Warna-32x32.webp\" sizes=\"32x32\" \/>\n    <link rel=\"icon\" href=\"\/assets\/img\/cropped-Jatelindo-Warna-192x192.webp\"\n        sizes=\"192x192\" \/>\n    <link rel=\"apple-touch-icon\" href=\"\/assets\/img\/cropped-Jatelindo-Warna-180x180.webp\" \/>\n    <link rel=\"shortcut icon\" href=\"\/assets\/img\/icon-launcher.png\" \/>\n    <link rel=\"preconnect\" href=\"https:\/\/fonts.googleapis.com\" \/>\n    <link rel=\"preconnect\" href=\"https:\/\/fonts.gstatic.com\" crossorigin \/>\n    <link href=\"https:\/\/fonts.googleapis.com\/css2?family=Sora:wght@100..800&display=swap\" rel=\"stylesheet\" \/>\n    <style>\n    body {\n        font-family: \"Sora\", sans-serif;\n        margin: 0;\n        padding: 0;\n        background-color: #f4f4f4;\n        -webkit-text-size-adjust: 100%;\n        -ms-text-size-adjust: 100%;\n    }\n\n    table {\n        border-collapse: collapse !important;\n    }\n\n    .container {\n        width: 80%;\n        max-width: 100%;\n        margin: 0 auto;\n        background-color: #ffffff;\n        border-radius: 0;\n        overflow: hidden;\n    }\n\n    .pre-code {\n        background: #f3f3f7;\n        display: block;\n        font-size: 1.2rem;\n        font-weight: bold;\n        letter-spacing: 4px;\n        padding: 10px 12px;\n        border: 1px solid #ebebf2;\n        border-radius: 8px;\n        width: fit-content;\n    }\n\n    .header {\n        background-image: url('assets\/img\/Background.svg');\n        background-size: cover;\n        background-position: top center;\n        background-repeat: no-repeat;\n        color: #ffffff;\n        padding: 32px;\n        margin: 0;\n        display: block;\n    }\n\n    .content-cell {\n        padding: 32px !important;\n        \/* Memaksa padding 32px atas, bawah, kanan, kiri *\/\n        color: #333333;\n        line-height: 1.6;\n        text-align: left;\n    }\n\n    \/* Selector h2 disesuaikan dengan pembungkus barunya *\/\n    .content-cell h2 {\n        margin-top: 0;\n        margin-bottom: 24px;\n        font-size: 20px;\n        color: #000000;\n        font-weight: 400;\n        \/* \"Halo,\" reguler *\/\n        text-align: left;\n    }\n\n    .content-cell h2 strong {\n        font-weight: 700;\n        \/* Variabel bold *\/\n    }\n\n    .content-cell p {\n        margin-top: 0;\n        \/* margin-bottom: 16px; *\/\n        font-size: 14px;\n        color: #1c1c1c;\n        text-align: left;\n    }\n\n    .info-table {\n        width: 100%;\n        margin-top: 16px;\n        border-collapse: collapse;\n    }\n\n    .info-table td {\n        padding: 8px 0;\n        \/* Jarak vertikal antar baris *\/\n        vertical-align: top;\n        font-size: 15px;\n        color: #1c1c1c;\n    }\n\n    .info-table .label {\n        width: 180px;\n        \/* Lebar kolom kiri agar teks muat satu baris *\/\n        white-space: nowrap;\n        \/* Memaksa teks label tetap lurus ke samping *\/\n        font-weight: 400;\n        \/* Memastikan teks kiri TIDAK TEBAL (Reguler) *\/\n    }\n\n    .info-table .colon {\n        width: 20px;\n        \/* Jarak untuk tanda titik dua (:) agar lurus vertikal *\/\n        text-align: center;\n        font-weight: 400;\n        \/* Titik dua tidak tebal *\/\n    }\n\n    .info-table .value {\n        font-weight: 700;\n        \/* Membuat variabel {{...}} di sebelah kanan menjadi TEBAL *\/\n    }\n\n    .label {\n        width: 120px;\n        font-weight: bold;\n    }\n\n    .footer {\n        background-color: #f9f9f9;\n        padding: 24px 32px;\n        text-align: center;\n        font-size: 12px;\n        color: #888888;\n        border-top: 1px solid #eeeeee;\n    }\n\n    .btn-link {\n        color: #007bff;\n        text-decoration: none;\n        font-weight: bold;\n    }\n\n    .btn-click {\n        display: inline-block;\n        background-color: #3A7BF6;\n        \/* Sesuai Hex di Figma *\/\n        color: #ffffff;\n        \/* Warna teks putih *\/\n        font-family: \"Sora\", sans-serif;\n        font-size: 14px;\n        font-weight: 700;\n        \/* Bold *\/\n        text-decoration: none;\n        \/* Menghilangkan garis bawah tautan *\/\n        padding: 10px 16px;\n        \/* Padding sesuai Figma (Top\/Bottom Left\/Right) *\/\n        line-height: 28px;\n        \/* Menjaga total tinggi elemen mendekati 48px *\/\n        border-radius: 8px;\n        \/* Radius sesuai Figma *\/\n        text-align: center;\n    }\n\n    hr {\n        border: 0;\n        border-top: 1px solid #eeeeee;\n        margin: 30px 0;\n    }\n\n    @media only screen and (min-width: 651px) {\n        body {\n            background-color: #f4f4f4;\n            color: #12161c;\n        }\n\n        .logo-white {\n            display: none !important;\n        }\n\n        .logo-dark {\n            display: block !important;\n        }\n\n        .pre-code {\n            font-size: 1.5rem !important;\n        }\n\n        .text-company {\n            color: #888a8d !important;\n        }\n\n        .text-company,\n        .font-heading,\n        .font-body {\n            font-size: 1rem !important;\n        }\n\n        .font-heading,\n        .font-body {\n            color: #12161c !important;\n        }\n    }\n\n    \/* ==========================================================================\n   Responsive Queries (Mobile \/ Layar Kecil)\n   ========================================================================== *\/\n    @media screen and (max-width: 650px) {\n\n        body {\n            background-color: #ffffff !important;\n        }\n\n        \/* Membalik urutan susunan Header (Logo di atas, teks di bawah) *\/\n        .header-table {\n            display: table !important;\n            width: 100% !important;\n        }\n\n        .header-table tr {\n            display: table !important;\n            width: 100% !important;\n        }\n\n        .header-table .header-logo {\n            display: table-header-group !important;\n            width: 100% !important;\n            text-align: left !important;\n            padding-bottom: 8px !important;\n            \/* Jarak dari logo ke elemen di bawahnya *\/\n        }\n\n        .header-table .header-title {\n            display: table-footer-group !important;\n            width: 100% !important;\n            text-align: left !important;\n            font-size: 20px !important;\n            \/* Mengecilkan font jadi 20px *\/\n            padding-top: 18px !important;\n            \/* Memberikan padding top 18px *\/\n        }\n\n        .header-table .header-logo img {\n            margin: 0 !important;\n        }\n\n        \/* --- Perbaikan Info Table Agar Tidak Terpotong di Mobile --- *\/\n        .info-table .label {\n            width: 135px !important;\n            \/* Mempersempit kolom label agar sisa kolom kanan luas *\/\n            white-space: normal !important;\n            font-size: 14px !important;\n        }\n\n        .info-table .colon {\n            width: 15px !important;\n        }\n\n        .info-table .value {\n            font-size: 14px !important;\n            word-break: break-word;\n            \/* Teks variabel panjang otomatis patah baris dengan aman *\/\n        }\n    }\n\n    \/* ==========================================================================\n    Responsive Queries (Dark Mode Global - Dipisah, Tidak Boleh Bersarang)\n   =============================================