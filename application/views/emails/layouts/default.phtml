            display: table !important;
            width: 100% !important;
        }

        .header-table .header-logo {
            display: table-header-group !important;
            width: 100% !important;
            text-align: left !important;
            padding-bottom: 8px !important;
            /* Jarak dari logo ke elemen di bawahnya */
        }

        .header-table .header-title {
            display: table-footer-group !important;
            width: 100% !important;
            text-align: left !important;
            font-size: 20px !important;
            /* Mengecilkan font jadi 20px */
            padding-top: 18px !important;
            /* Memberikan padding top 18px */
        }

        .header-table .header-logo img {
            margin: 0 !important;
        }

        /* --- Perbaikan Info Table Agar Tidak Terpotong di Mobile --- */
        .info-table .label {
            width: 135px !important;
            /* Mempersempit kolom label agar sisa kolom kanan luas */
            white-space: normal !important;
            font-size: 14px !important;
        }

        .info-table .colon {
            width: 15px !important;
        }

        .info-table .value {
            font-size: 14px !important;
            word-break: break-word;
            /* Teks variabel panjang otomatis patah baris dengan aman */
        }
    }

    /* ==========================================================================
    Responsive Queries (Dark Mode Global - Dipisah, Tidak Boleh Bersarang)
   ========================================================================== */
    @media (prefers-color-scheme: dark) {
        body {
            background-color: #2a2d33 !important;
        }

        .logo-white {
            display: block !important;
        }

        .pre-code {
            background-color: #727272 !important;
            border-color: #727272 !important;
        }

        .border-color {
            border-left: 1px solid #5a5a5a !important;
            border-right: 1px solid #5a5a5a !important;
        }

        .border-color-2 {
            border-left: 1px solid #5a5a5a !important;
            border-right: 1px solid #5a5a5a !important;
            border-bottom: 1px solid #5a5a5a !important;
        }

        .hr {
            margin: 0 !important;
            padding: 0 !important;
            border: 1px solid #e7e8e8 !important;
        }

        .text-company,
        .font-heading,
        .font-body {
            color: #fff !important;
        }
