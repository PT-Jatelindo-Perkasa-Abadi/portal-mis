    <style>
    body {
        font-family: "Sora", sans-serif;
        margin: 0;
        padding: 0;
        background-color: #f4f4f4;
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
    }

    table {
        border-collapse: collapse !important;
    }

    .container {
        width: 80%;
        max-width: 100%;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 0;
        overflow: hidden;
    }

    .pre-code {
        background: #f3f3f7;
        display: block;
        font-size: 1.2rem;
        font-weight: bold;
        letter-spacing: 4px;
        padding: 10px 12px;
        border: 1px solid #ebebf2;
        border-radius: 8px;
        width: fit-content;
    }

    .header {
        background-image: url('<?= $this->backgroundHeader; ?>');
        background-size: cover;
        background-position: top center;
        background-repeat: no-repeat;
        color: #ffffff;
        padding: 32px;
        margin: 0;
        display: block;
    }

    .content-cell {
        padding: 32px !important;
        /* Memaksa padding 32px atas, bawah, kanan, kiri */
        color: #333333;
        line-height: 1.6;
        text-align: left;
    }

    /* Selector h2 disesuaikan dengan pembungkus barunya */
    .content-cell h2 {
        margin-top: 0;
        margin-bottom: 24px;
        font-size: 20px;
        color: #000000;
        font-weight: 400;
        /* "Halo," reguler */
        text-align: left;
    }

    .content-cell h2 strong {
        font-weight: 700;
        /* Variabel bold */
    }

    .content-cell p {
        margin-top: 0;
        /* margin-bottom: 16px; */
        font-size: 14px;
        color: #1c1c1c;
        text-align: left;
    }

    .info-table {
        width: 100%;
        margin-top: 16px;
        border-collapse: collapse;
    }

    .info-table td {
        padding: 8px 0;
        /* Jarak vertikal antar baris */
        vertical-align: top;
        font-size: 15px;
        color: #1c1c1c;
    }

    .info-table .label {
        width: 180px;
        /* Lebar kolom kiri agar teks muat satu baris */
        white-space: nowrap;
        /* Memaksa teks label tetap lurus ke samping */
        font-weight: 400;
        /* Memastikan teks kiri TIDAK TEBAL (Reguler) */
    }

    .info-table .colon {
        width: 20px;
        /* Jarak untuk tanda titik dua (:) agar lurus vertikal */
        text-align: center;
        font-weight: 400;
        /* Titik dua tidak tebal */
    }

    .info-table .value {
        font-weight: 700;
        /* Membuat variabel {{...}} di sebelah kanan menjadi TEBAL */
    }

    .label {
        width: 120px;
        font-weight: bold;
    }

    .footer {
        background-color: #f9f9f9;
        padding: 24px 32px;
        text-align: center;
        font-size: 12px;
        color: #888888;
        border-top: 1px solid #eeeeee;
    }

    .btn-link {
        color: #007bff;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-click {
        display: inline-block;
        background-color: #3A7BF6;
        /* Sesuai Hex di Figma */
        color: #ffffff !important;
        /* Warna teks putih */
        font-family: "Sora", sans-serif;
        font-size: 14px;
        font-weight: 700;
        /* Bold */
        text-decoration: none;
        /* Menghilangkan garis bawah tautan */
        padding: 10px 16px;
        /* Padding sesuai Figma (Top/Bottom Left/Right) */
        line-height: 28px;
        /* Menjaga total tinggi elemen mendekati 48px */
        border-radius: 8px;
        /* Radius sesuai Figma */
        text-align: center;
    }

    hr {
        border: 0;
        border-top: 1px solid #eeeeee;
        margin: 30px 0;
    }

    @media only screen and (min-width: 651px) {
        body {
            background-color: #f4f4f4;
            color: #12161c;
        }

        .logo-white {
            display: none !important;
        }

        .logo-dark {
            display: block !important;
        }

        .pre-code {
            font-size: 1.5rem !important;
        }

        .text-company {
            color: #888a8d !important;
        }

        .text-company,
        .font-heading,
        .font-body {
            font-size: 1rem !important;
        }

        .font-heading,
        .font-body {
            color: #12161c !important;
        }
